<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Casino Bac Bo</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-..." crossorigin="anonymous">

    <style>
        body {
            background-color: #0b0c2a;
            color: #fff;
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
        }

        .navbar {
            background-color: #111;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .navbar a {
                color: #FFD700;
                text-decoration: none;
                font-weight: 600;
                margin-left: 1.5rem;
            }

                .navbar a:hover {
                    color: white;
                }

        .container {
            padding: 2rem;
        }

        .casino-title {
            font-family: 'Cinzel', serif;
            font-size: 2.5rem;
            text-align: center;
            color: #FFD700;
            margin-bottom: 2rem;
            text-shadow: 0 0 10px #FFD70088;
        }

        .game-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 2rem;
            justify-content: center;
        }

        .game-card {
            background-color: rgba(255, 255, 255, 0.05);
            border: 2px solid #FFD70055;
            border-radius: 15px;
            padding: 1.5rem;
            text-align: center;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .game-card:hover {
                transform: scale(1.03);
                box-shadow: 0 0 15px #FFD70088;
                cursor: pointer;
            }

            .game-card h3 {
                color: #FFD700;
                font-family: 'Cinzel', serif;
            }

        footer {
            background-color: #111;
            text-align: center;
            padding: 1rem;
            margin-top: 2rem;
            font-size: 0.9rem;
            color: #aaa;
        }
    </style>
</head>
<body>
    <div class="navbar">
        <div style="font-family: 'Cinzel', serif; font-size: 1.5rem; color: #FFD700;">🎰 Cassino Bac Bo</div>
        <div>
            <a href="/">Home</a>
            <a href="/Home/BacBo">Bac Bo</a>
            <a href="/Home/PainelADM">Admin</a>
        </div>
    </div>

    <div class="container">
        @RenderBody()
    </div>

    <footer>
        &copy; 2025 Cassino Bac Bo  
    </footer>
</body>
</html>
